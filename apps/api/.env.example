APP_NAME=Autonomous Trading Portal API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://tradingbot:tradingbot@localhost:5432/tradingbot
CORS_ORIGINS=http://localhost:3000
# mock = simulated Web3 DEX routes; live = on-chain DEX cross-venue scanner; ccxt = legacy CEX-only scanner
MARKET_MODE=live
EXECUTION_MODE=simulation
SCAN_INTERVAL_SECONDS=12
DEFAULT_WALLET_ADDRESS=0x9C1A8D7F0B4c0A6b6a8E7d701C4A3147D0b8e3f5
DEFAULT_PROFIT_THRESHOLD_USD=35
DEFAULT_MAX_TRADE_SIZE_USD=2500
DEFAULT_DAILY_LOSS_LIMIT_USD=900
DEFAULT_STOP_LOSS_PERCENT=2.5
DEFAULT_ALLOWED_SLIPPAGE_BPS=70
AUTO_EXECUTE_DEFAULT=true
WALLETCONNECT_PROJECT_ID=
ALCHEMY_API_KEY=
INFURA_API_KEY=
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=
# Web3 scanner (MARKET_MODE=live): RPC URLs for gas estimates; DexScreener needs no API key
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
WEB3_MIN_LIQUIDITY_USD=50000
WEB3_MIN_SPREAD_BPS=3
